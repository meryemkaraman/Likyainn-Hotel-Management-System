 
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Likya Inn Fethiye</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="logo-icon">⛵</span>
                Likya Inn
            </a>

            <div class="collapse navbar-collapse" id="navbarMenu">
                <ul class="navbar-nav ms-auto align-items-center gap-1">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Odalar">Odalar</a>
                    </li>
                    @if (Context.Session.GetString("KullaniciAdi") != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Home/Profil">
                                👋 Merhaba @Context.Session.GetString("KullaniciAdi")
                            </a>
                        </li>
                    }
                    
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Giris">Üye Girişi</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <div class="footer-content">
                <div class="footer-brand">
                    <h4>⛵ Likya Inn</h4>
                    <p>Fethiye'nin en güzel koylarından birine bakan,<br>huzur dolu butik otelimize hoş geldiniz.</p>
                </div>
                <div class="footer-section">
                    <h5>Hızlı Erişim</h5>
                    <a asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                    <a asp-controller="Home" asp-action="Odalar">Odalar</a>
                    <a asp-controller="Home" asp-action="Giris">Üye Girişi</a>
                </div>
                <div class="footer-section">
                    <h5>İletişim</h5>
                    <p>📍 Çalış Plajı, Fethiye / Muğla</p>
                    <p>📞 +90 252 614 00 00</p>
                    <p>✉️ likyainn@gmail.com.</p>
                </div>
                <div class="footer-section">
                    <h5>Çalışma Saatleri</h5>
                    <p>Resepsiyon: 7/24 Açık</p>
                    <p>Kahvaltı: 07:30 – 10:30</p>
                    <p>Restoran: 12:00 – 22:00</p>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; @DateTime.Now.Year Likya Inn Fethiye. Tüm hakları saklıdır. | Ege'nin incisi, Fethiye'nin kalbi. 💙</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>