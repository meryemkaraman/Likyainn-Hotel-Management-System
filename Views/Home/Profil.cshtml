<style>
    .profile-container {
        max-width: 1000px;
        margin: 30px auto;
    }

    .profile-card {
        background: white;
        padding: 20px;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        margin-bottom: 20px;
    }

    .profile-title {
        font-size: 26px;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .info-box {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
    }

    .info-item {
        flex: 1;
        min-width: 200px;
        background: #f4f7ff;
        padding: 15px;
        border-radius: 12px;
    }

        .info-item span {
            font-weight: bold;
            display: block;
            margin-bottom: 5px;
        }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
    }

        table th {
            background: #1f4e79;
            color: white;
            padding: 10px;
        }

        table td {
            padding: 10px;
            border-bottom: 1px solid #ddd;
        }

    .badge {
        background: #2e8b57;
        color: white;
        padding: 4px 8px;
        border-radius: 8px;
        font-size: 12px;
    }
</style>

<div class="profile-container">

    <div class="profile-card">
        <div class="profile-title">👤 Profil Sayfası</div>

        <div class="info-box">
            <div class="info-item">
                <span>Ad</span>
                @ViewBag.Kullanici.Ad
            </div>

            <div class="info-item">
                <span>Kullanıcı Adı</span>
                @ViewBag.Kullanici.KullaniciAdi
            </div>

            <div class="info-item">
                <span>Email</span>
                @ViewBag.Kullanici.Email
            </div>
        </div>
    </div>

    <div class="profile-card">
        <div class="profile-title">📋 Rezervasyonlarım</div>

        <table>
            <thead>
                <tr>
                    <th>Oda</th>
                    <th>Giriş</th>
                    <th>Çıkış</th>
                    <th>Tutar</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var r in ViewBag.Rezervasyonlar)
                {
                    <tr>
                        <td><span class="badge">@r.OdaTipi</span></td>
                        <td>@r.GirisTarihi.ToShortDateString()</td>
                        <td>@r.CikisTarihi.ToShortDateString()</td>
                        <td>@r.ToplamTutar ₺</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>