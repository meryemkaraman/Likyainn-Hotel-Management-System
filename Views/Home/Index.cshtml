@{
    ViewData["Title"] = "Ana Sayfa";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<section class="ust-bolum">
    <div class="ust-icerik">
        <div class="ust-logo-icon">⛵</div>
        <h1 class="ust-baslik">LİKYA INN</h1>
        <p class="ust-altbaslik">Butik Otel &amp; Spa · Fethiye</p>
        <div class="ust-ayrac"></div>
        <p class="ust-aciklama">Ege'nin mavilikleriyle iç içe, Fethiye'nin kalbinde huzur bulun.</p>
        <p style="color: #fff; opacity: 0.85; font-size: 0.95rem; margin-bottom: 2rem;">
            🔑 Üye olan misafirlerimize tüm odalarda <strong>%10 indirim</strong> fırsatı!
        </p>

        
        <div class="ust-butonlar">
            <a href="/Home/Odalar" class="btn-rezervasyon">
                📅 Hemen Rezervasyon Yap
            </a>
            <a href="/Home/Kayit" class="btn-giris">
                📝 Üye Ol
            </a>
        </div>
    </div>
</section></section>


<section class="bolum" style="background: var(--kum);">
    <div class="container">
        <h2 class="bolum-baslik">Fethiye'den Kareler</h2>
        <div class="bolum-ayrac"></div>

        <div class="fethiye-galeri-kapsayici">
          

            <div class="galeri-grid">

                <div class="galeri-item">
                    <img src="/images/oludeniz.jpg" alt="Ölüdeniz" />
                    <div class="galeri-etiket">Ölüdeniz</div>
                </div>

                <div class="galeri-item">
                    <img src="/images/bbdg.jpg" alt="Babadağ" />
                    <div class="galeri-etiket">Babadağ</div>
                </div>

                <div class="galeri-item">
                    <img src="/images/kelebekvadi.jpg" alt="Kelebekler Vadisi" />
                    <div class="galeri-etiket">Kelebekler Vadisi</div>
                </div>

                <div class="galeri-item">
                    <img src="/images/sklknt.jpg" alt="Saklıkent" />
                    <div class="galeri-etiket">Saklıkent Kanyonu</div>
                </div>

                <div class="galeri-item">
                    <img src="/images/kyky.jpg" alt="Kayaköy" />
                    <div class="galeri-etiket">Kayaköy</div>
                </div>

                <div class="galeri-item">
                    <img src="/images/krlmzr.jpg" alt="Likya Kaya Mezarları" />
                    <div class="galeri-etiket">Likya Kaya Mezarları</div>
                </div>

            </div>

</section>

<section class="bolum" style="background: var(--beyaz);">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-5 text-center">
                <div style="font-size: 9rem; line-height: 1; filter: drop-shadow(0 8px 20px rgba(26,58,92,0.15));">
                    ⛵
                </div>
            </div>
            <div class="col-lg-7">
                <h2 class="bolum-baslik" style="text-align:left;">Hakkımızda</h2>
                <div class="bolum-ayrac" style="margin-left:0;"></div>

                <div class="hakkimizda-kart">
                    <p>
                        Fethiye'nin eşsiz doğasında, Ege'nin mavi rüzgarlarıyla sizi karşılayan <strong>Likya Inn</strong>,
                        2010 yılından bu yana misafirlerine unutulmaz tatil deneyimleri sunmaktadır.
                    </p>
                    <p>
                        Çalış Plajı'na yürüme mesafesinde konumlanan otelimiz; modern konforu sıcak ev atmosferiyle
                        buluşturan özel tasarımı, açık havuz ve spa hizmetleriyle her yaştan misafir için
                        mükemmel bir kaçış noktasıdır.
                    </p>

                    <div class="hakkimizda-ozellikler">
                        <span class="ozellik-etiket">🏊 Açık Yüzme Havuzu</span>
                        <span class="ozellik-etiket">🍳 Serpme Kahvaltı</span>
                        <span class="ozellik-etiket">💆 Spa & Masaj</span>
                        <span class="ozellik-etiket">🌊 Plaja 5 Dakika</span>
                        <span class="ozellik-etiket">🅿️ Ücretsiz Park</span>
                        <span class="ozellik-etiket">📶 Ücretsiz WiFi</span>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

<section class="bolum" style="background: var(--kum);">
    <div class="container">
        <h2 class="bolum-baslik">Bize Ulaşın</h2>
        <div class="bolum-ayrac"></div>

        <div class="iletisim-grid">
            <div class="iletisim-kart">
                <div class="iletisim-icon">📍</div>
                <h5>Adres</h5>
                <p>Çalış Mah. Likya Cad. No:42<br>Fethiye / Muğla, 48300</p>
            </div>

            <div class="iletisim-kart">
                <div class="iletisim-icon">📞</div>
                <h5>Telefon</h5>
                <p>+90 545 532 90 12<br>+90 000 000 00 00</p>
            </div>

            <div class="iletisim-kart">
                <div class="iletisim-icon">✉️</div>
                <h5>E-Posta</h5>
                <p>info@likyainn.com.tr<br>rezervasyon@likyainn.com.tr</p>
            </div>

            <div class="iletisim-kart">
                <div class="iletisim-icon">🕐</div>
                <h5>Giriş / Çıkış Saatleri</h5>
                <p>Giriş: 14:00<br>Çıkış: 12:00</p>
            </div>
        </div>

        
        <div class="harita-alani mt-4" style="overflow:hidden; padding:0;">

            <span class="harita-icon">🗺️</span>
            <strong>Google Haritalar – Likya Inn Fethiye</strong>

            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d25602.584301531442!2d29.0793868975422!3d36.66673332623482!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14c04307671d9175%3A0x31cad76a7a86d646!2zw4dhbMSxxZ8gUGxhasSx!5e0!3m2!1str!2str!4v1776717390547!5m2!1str!2str"
                    width="100%"
                    height="300"
                    style="border:0;"
                    allowfullscreen=""
                    loading="lazy">
            </iframe>

        </div>
    </div>
</section>
