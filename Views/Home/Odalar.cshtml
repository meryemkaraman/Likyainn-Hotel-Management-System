                            "<div class='col-lg-6'>" +
                                "<div class='detay-info-card'>" +
                                    "<h1>" + oda.ad + "</h1>" +
                                    "<div style='display:flex; gap:0.8rem; margin:0.8rem 0 1.2rem; flex-wrap:wrap;'>" +
                                        premiumHtml +
                                        "<span class='feature-badge'>👥 " + odaKapasite[tipAdi].min + "-" + odaKapasite[tipAdi].max + " Kişi</span>" +
                                        "<span class='feature-badge'>📐 " + oda.m2 + " m²</span>" +
                                        "<span class='feature-badge'>🌊 Deniz Manzarası</span>" +
                                    "</div>" +
                                    "<p style='color:var(--metin-orta); line-height:1.8; margin-bottom:1.5rem; font-size:1rem;'>" +
                                        tip.ad + " kategorisindeki " + oda.ad + " odamız, size eşsiz bir konaklama deneyimi sunmak için özenle hazırlanmıştır." +
                                    "</p>" +
                                    "<h5 style='color:var(--ege-koyu); margin-bottom:1rem; font-size:1.05rem;'>🏠 Oda Özellikleri</h5>" +
                                    "<ul class='detay-ozellik-listesi'>" + ozHtml + "</ul>" +
                                    "<div style='background:var(--ege-cok-acik); border-radius:14px; padding:1.2rem 1.5rem; margin-top:1.5rem; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem;'>" +
                                        "<div>" +
                                            "<div style='font-size:0.85rem; color:var(--metin-orta);'>Gecelik fiyat</div>" +
                                            "<div class='fiyat-yeni' style='font-size:2rem;'>" + Number(oda.fiyat).toLocaleString('tr-TR') + " ₺ <span>/ gece</span></div>" +
                                        "</div>" +
                                        "<div style='font-size:0.8rem; color:var(--metin-orta); max-width:180px;'>✅ Ücretsiz iptal (3 gün öncesine kadar)</div>" +
                                    "</div>" +
                                    "<a href='/Home/Rezervasyon?odaTipi=" + encodeURIComponent(tipAdi) + "' class='btn-ayirt'>📋 Bu Odayı Ayırt</a>" +
                                "</div>" +
                            "</div>" +
                        "</div>" +
                        uyeDavetHtml +
                    "</div>" +
                "</div>";

            detayView.classList.add("goster");
            detayView.scrollIntoView({ behavior: "smooth", block: "start" });
        }

        var gorselIndex = 0;
        function gorselDegistir(odaId, idx) {
            gorselIndex = idx;
            var oda = null;
            for (var katAdi in odaTipleri) {
                for (var i = 0; i < odaTipleri[katAdi].odalar.length; i++) {
                    if (odaTipleri[katAdi].odalar[i].id === odaId) { oda = odaTipleri[katAdi].odalar[i]; break; }
                }
                if (oda) break;
            }
            if (!oda) return;
            var g = oda.gorseller && oda.gorseller[idx] ? oda.gorseller[idx] : "Görsel Ekle";
            var anaGorsel = document.getElementById("detayAnaGorsel");
            if (anaGorsel) {
                if (g && g.startsWith("http")) {
                    anaGorsel.outerHTML = "<img id='detayAnaGorsel' src='" + g + "' alt='" + oda.ad + "' style='width:100%;height:100%;object-fit:cover;border-radius:20px;' />";
                } else {
                    anaGorsel.outerHTML = "<div id='detayAnaGorsel' style='width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:1.2rem;font-weight:700;color:var(--ege-koyu);'>" + g + "</div>";
                }
            }
        }

        // --- DROPDOWN SECIM ---
        var optionlar = document.querySelectorAll(".oda-selector-option");
        for (var i = 0; i < optionlar.length; i++) {
            (function(opt) {
                opt.addEventListener("click", function() {
                    var tip = this.getAttribute("data-tip");

                    for (var j = 0; j < optionlar.length; j++)
                        optionlar[j].classList.remove("secili");
                    this.classList.add("secili");

                    if (tip === "tumu") {
                        textBox.innerHTML = "🏠 Tüm Odalar";
                        dropdown.classList.remove("acik");
                        filtreAktif = false;
                        tumOdalariGoster();
                    } else {
                        textBox.innerHTML = odaTipleri[tip].emoji + " " + odaTipleri[tip].ad;
                        dropdown.classList.remove("acik");
                        filtreAktif = false;
                        kupGoster(tip);
                    }
                });
            })(optionlar[i]);
        }

        // --- SAYFA YUKLENINCE TUM ODALARI GOSTER ---
        tumOdalariGoster();

        // --- FILTRE OLAY DINLEYICILERI ---
        filtreMinInput.addEventListener("input", function() {
            var val = parseInt(this.value);
            var maxVal = parseInt(filtreMaxInput.value);
            var step = parseInt(this.step || 100);
            if (val >= maxVal) this.value = Math.max(parseInt(this.min), maxVal - step);
            filtreMinDegerSpan.textContent = parseInt(this.value).toLocaleString('tr-TR') + " ₺";
        });

        filtreMaxInput.addEventListener("input", function() {
            var val = parseInt(this.value);
            var minVal = parseInt(filtreMinInput.value);
            var step = parseInt(filtreMaxInput.step || 100);
            if (val <= minVal) this.value = Math.min(parseInt(this.max), minVal + step);
            filtreMaxDegerSpan.textContent = parseInt(this.value).toLocaleString('tr-TR') + " ₺";
        });

        filtreUygulaBtn.addEventListener("click", filtreyiUygula);

        kisiMinInput.addEventListener("input", function() {
            var val = parseInt(this.value);
            var maxVal = parseInt(kisiMaxInput.value);
            if (val >= maxVal) this.value = Math.max(parseInt(this.min), maxVal - 1);
            kisiMinDegerSpan.textContent = parseInt(this.value);
        });

        kisiMaxInput.addEventListener("input", function() {
            var val = parseInt(this.value);
            var minVal = parseInt(kisiMinInput.value);
            if (val <= minVal) this.value = Math.min(parseInt(this.max), minVal + 1);
            kisiMaxDegerSpan.textContent = parseInt(this.value);
        });
    </script>
    <script>
        var uyeGiris = @Html.Raw(Json.Serialize(ViewBag.UyeGiris));
    </script>
}