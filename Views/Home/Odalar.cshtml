        function tumOdalariGetir() {
            var sonuc = [];
            for (var katAdi in odaTipleri) {
                var kat = odaTipleri[katAdi];
                for (var i = 0; i < kat.odalar.length; i++) {
                    sonuc.push({ oda: kat.odalar[i], tip: katAdi });
                }
            }
            return sonuc;
        }

        function filtreAralikGuncelle() {
            var min = Infinity, max = -Infinity;
            var kMin = Infinity, kMax = -Infinity;
            var hepsi = tumOdalariGetir();
            for (var i = 0; i < hepsi.length; i++) {
                var f = hepsi[i].oda.fiyat;
                if (f < min) min = f;
                if (f > max) max = f;
            }
            // kisi araligi odaKapasite'den
            for (var tip in odaKapasite) {
                if (odaKapasite[tip].min < kMin) kMin = odaKapasite[tip].min;
                if (odaKapasite[tip].max > kMax) kMax = odaKapasite[tip].max;
            }

            filtreMinInput.min = min;
            filtreMinInput.max = max;
            filtreMaxInput.min = min;
            filtreMaxInput.max = max;

            kisiMinInput.min = kMin;
            kisiMinInput.max = kMax;
            kisiMaxInput.min = kMin;
            kisiMaxInput.max = kMax;

            if (seciliTip) {
                var kat = odaTipleri[seciliTip];
                var pMin = Infinity, pMax = -Infinity;
                for (var i = 0; i < kat.odalar.length; i++) {
                    var f = kat.odalar[i].fiyat;
                    if (f < pMin) pMin = f;
                    if (f > pMax) pMax = f;
                }
                filtreMinInput.min = pMin;
                filtreMinInput.max = pMax;
                filtreMaxInput.min = pMin;
                filtreMaxInput.max = pMax;
                kisiMinInput.min = odaKapasite[seciliTip].min;
                kisiMinInput.max = odaKapasite[seciliTip].max;
                kisiMaxInput.min = odaKapasite[seciliTip].min;
                kisiMaxInput.max = odaKapasite[seciliTip].max;
            }

            if (!filtreAktif) {
                filtreMinInput.value = parseInt(filtreMinInput.min);
                filtreMaxInput.value = parseInt(filtreMaxInput.max);
                filtreMinVal = parseInt(filtreMinInput.value);
                filtreMaxVal = parseInt(filtreMaxInput.value);
                kisiMinInput.value = parseInt(kisiMinInput.min);
                kisiMaxInput.value = parseInt(kisiMaxInput.max);
                kisiMinVal = parseInt(kisiMinInput.value);
                kisiMaxVal = parseInt(kisiMaxInput.value);
            } else {
                filtreMinInput.value = filtreMinVal;
                filtreMaxInput.value = filtreMaxVal;
                kisiMinInput.value = kisiMinVal;
                kisiMaxInput.value = kisiMaxVal;
            }

            filtreMinDegerSpan.textContent = parseInt(filtreMinInput.value).toLocaleString('tr-TR') + " ₺";
            filtreMaxDegerSpan.textContent = parseInt(filtreMaxInput.value).toLocaleString('tr-TR') + " ₺";
            kisiMinDegerSpan.textContent = parseInt(kisiMinInput.value);
            kisiMaxDegerSpan.textContent = parseInt(kisiMaxInput.value);
        }

        function filtreleOdalari(odaList, minF, maxF, minK, maxK) {
            var sonuc = [];
            for (var i = 0; i < odaList.length; i++) {
                var o = odaList[i].oda;
                var tip = odaList[i].tip;
                var cap = odaKapasite[tip];
                if (o.fiyat >= minF && o.fiyat <= maxF && cap.min <= maxK && cap.max >= minK) {
                    sonuc.push(odaList[i]);
                }
            }
            return sonuc;
        }

        function filtreyiUygula() {
            var minF = parseInt(filtreMinInput.value);
            var maxF = parseInt(filtreMaxInput.value);
            var stepF = parseInt(filtreMinInput.step || 100);
            if (minF >= maxF) { minF = Math.max(parseInt(filtreMinInput.min), maxF - stepF); maxF = minF + stepF; }
            filtreMinVal = minF;
            filtreMaxVal = maxF;

            var minK = parseInt(kisiMinInput.value);
            var maxK = parseInt(kisiMaxInput.value);
            if (minK >= maxK) { minK = Math.max(parseInt(kisiMinInput.min), maxK - 1); maxK = minK + 1; }
            kisiMinVal = minK;
            kisiMaxVal = maxK;

            filtreAktif = true;

            if (seciliTip) {
                kupGoster(seciliTip);
            } else {
                tumOdalariGoster();
            }
        }

