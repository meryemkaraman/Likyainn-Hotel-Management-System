            "</div>";
        }

        function kupGoster(tipAdi) {
            var tip = odaTipleri[tipAdi];
            if (!tip) return;

            seciliTip = tipAdi;
            oncekiGoruntu = tipAdi;
            detayView.classList.remove("goster");
