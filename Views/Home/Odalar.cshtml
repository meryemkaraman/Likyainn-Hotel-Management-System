                    var oda = kat.odalar[i];
                    if (filtreAktif && (oda.fiyat < filtreMinVal || oda.fiyat > filtreMaxVal || odaKapasite[katAdi].min > kisiMaxVal || odaKapasite[katAdi].max < kisiMinVal)) continue;
                    kupGrid.innerHTML += kupHtml(oda, katAdi);
                }
            }

            var inceleBtns = kupGrid.querySelectorAll(".kup-incele");
            for (var j = 0; j < inceleBtns.length; j++) {
                (function(btn) {
                    btn.addEventListener("click", function() {
                        detayGoster(this.getAttribute("data-tip"), this.getAttribute("data-oda-id"));
                    });
                })(inceleBtns[j]);
            }

            filtreAralikGuncelle();
        }

        function geriDon() {
