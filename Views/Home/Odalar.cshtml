 
@{
    ViewData["Title"] = "Odalarımız";
    bool uyeGiris = Context.Request.Query["uyeGiris"] == "true" || (bool)(ViewBag.UyeGiris ?? false);
}

<style>
    .oda-selector {
        position: relative;
        width: 100%;
        max-width: 400px;
        margin: 0 auto 2rem;
        z-index: 100;
    }

    .oda-selector-text {
        background: var(--beyaz);
        border: 2px solid var(--ege-orta);
        border-radius: 14px;
        padding: 1rem 1.5rem;
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--ege-koyu);
        cursor: pointer;
        text-align: center;
        font-family: 'Playfair Display', serif;
        transition: border-color 0.3s, box-shadow 0.3s;
        user-select: none;
    }

        .oda-selector-text:hover {
            border-color: var(--altin);
            box-shadow: 0 4px 20px rgba(201,168,76,0.25);
        }

    .oda-selector-dropdown {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        right: 0;
        background: var(--beyaz);
        border-radius: 14px;
        box-shadow: 0 12px 40px rgba(26,58,92,0.2);
        overflow: hidden;
        opacity: 0;
        pointer-events: none;
        transition: opacity 1s ease;
    }

        .oda-selector-dropdown.acik {
            opacity: 1;
            pointer-events: auto;
        }

    .oda-selector-option {
        padding: 1rem 1.5rem;
        font-size: 1rem;
        font-weight: 600;
        color: var(--metin-koyu);
        cursor: pointer;
        transition: background 0.2s, padding-left 0.2s;
        border-bottom: 1px solid var(--kum);
        display: flex;
        align-items: center;
        gap: 0.8rem;
    }

        .oda-selector-option:last-child {
            border-bottom: none;
        }

        .oda-selector-option:hover {
            background: var(--ege-cok-acik);
            padding-left: 2rem;
        }

        .oda-selector-option.secili {
            background: var(--ege-cok-acik);
            color: var(--ege-koyu);
            font-weight: 700;
        }

        .oda-selector-option .oda-emoji {
            font-size: 1.8rem;
        }

    .kup-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        max-width: 900px;
        margin: 0 auto;
    }

    .kup-kart {
        background: var(--beyaz);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 6px 25px rgba(26,58,92,0.1);
        transition: transform 0.3s, box-shadow 0.3s;
        display: flex;
        flex-direction: column;
    }

        .kup-kart:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 35px rgba(26,58,92,0.18);
        }

    .kup-gorsel {
        aspect-ratio: 4/3;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        font-weight: 600;
        color: var(--metin-orta);
        opacity: 0.5;
        border-bottom: 1px solid var(--kum);
        overflow: hidden;
    }

        .kup-gorsel img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .kup-bilgi {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.8rem 1rem;
        background: var(--ege-cok-acik);
    }

    .kup-fiyat {
        font-weight: 700;
        color: var(--ege-koyu);
        font-size: 1rem;
    }

    .kup-m2 {
        font-size: 0.85rem;
        color: var(--metin-orta);
        font-weight: 600;
    }

    .kup-incele {
        display: block;
        width: 100%;
        padding: 0.7rem;
        background: linear-gradient(135deg, var(--ege-orta), var(--ege-koyu));
        color: var(--beyaz);
        font-weight: 700;
        font-size: 0.9rem;
        text-align: center;
        cursor: pointer;
        border: none;
        transition: background 0.3s;
        letter-spacing: 0.3px;
    }

        .kup-incele:hover {
            background: linear-gradient(135deg, var(--ege-acik), var(--ege-orta));
        }

    .secim-yonlendirme {
        text-align: center;
        padding: 3rem 1rem;
        color: var(--metin-orta);
        font-size: 1.1rem;
    }

    #detayView {
        display: none;
    }

        #detayView.goster {
            display: block;
        }

    #detayView {
        animation: fadeIn 0.4s ease;
    }

    .detay-view-back {
        position: sticky;
        top: 80px;
        z-index: 10;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        color: var(--ege-orta);
        font-weight: 700;
        font-size: 0.95rem;
        cursor: pointer;
        margin-bottom: 1rem;
        transition: color 0.2s;
        border: none;
        background: var(--beyaz);
        padding: 0.6rem 1.2rem;
        border-radius: 10px;
        box-shadow: 0 2px 10px rgba(26,58,92,0.1);
    }

        .detay-view-back:hover {
            color: var(--ege-koyu);
        }

    .oda-detay-hero-foto {
        border-radius: 20px;
        height: 380px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 8rem;
        margin-bottom: 2rem;
        box-shadow: 0 8px 30px rgba(26,58,92,0.12);
    }

    /* FILTRE PANELI */
    .oda-sayfa-duzeni {
        display: flex;
        gap: 2rem;
        align-items: flex-start;
    }

    .oda-grid-alani {
        flex: 1;
        min-width: 0;
    }

    .filtre-panel {
        width: 260px;
        flex-shrink: 0;
        background: var(--beyaz);
        border-radius: 16px;
        padding: 1.5rem 1.5rem 2.2rem;
        box-shadow: 0 4px 20px rgba(26,58,92,0.08);
        position: sticky;
        top: 100px;
    }

        .filtre-panel .filtre-ust-baslik {
            font-size: 1.2rem;
            font-weight: 800;
            color: var(--ege-koyu);
            text-align: center;
            margin-bottom: 0.3rem;
        }

        .filtre-panel .filtre-alt-baslik {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--metin-orta);
            margin-bottom: 1rem;
        }

    .filtre-cizgi-wrap {
        position: relative;
        height: 30px;
        margin: 0.5rem 0 0.8rem;
    }

        .filtre-cizgi-wrap .filtre-cizgi {
            position: absolute;
            top: 12px;
            left: 0;
            width: 100%;
            height: 6px;
            background: var(--kum-koyu);
            border-radius: 3px;
            pointer-events: none;
        }

        .filtre-cizgi-wrap input[type="range"] {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 30px;
            -webkit-appearance: none;
            appearance: none;
            background: transparent;
            pointer-events: none;
            margin: 0;
        }

            .filtre-cizgi-wrap input[type="range"]::-webkit-slider-thumb {
                -webkit-appearance: none;
                appearance: none;
                width: 18px;
                height: 18px;
                border-radius: 50%;
                background: var(--ege-orta);
                cursor: pointer;
                pointer-events: auto;
                border: 3px solid var(--beyaz);
                box-shadow: 0 2px 6px rgba(26,58,92,0.25);
                transition: box-shadow 0.2s;
            }

                .filtre-cizgi-wrap input[type="range"]::-webkit-slider-thumb:hover {
                    box-shadow: 0 2px 10px rgba(26,58,92,0.35);
                }

            .filtre-cizgi-wrap input[type="range"]::-moz-range-thumb {
                width: 18px;
                height: 18px;
                border-radius: 50%;
                background: var(--ege-orta);
                cursor: pointer;
                pointer-events: auto;
                border: 3px solid var(--beyaz);
                box-shadow: 0 2px 6px rgba(26,58,92,0.25);
            }

    .filtre-degerler {
        display: flex;
        justify-content: space-between;
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--ege-koyu);
        margin-top: 0.8rem;
    }

        .filtre-degerler span {
            background: var(--ege-cok-acik);
            padding: 0.2rem 0.6rem;
            border-radius: 6px;
        }

    .filtre-uygula-btn {
        width: 100%;
        margin-top: 1.8rem;
        background: linear-gradient(135deg, var(--ege-orta), var(--ege-koyu));
        color: var(--beyaz);
        font-weight: 700;
        font-size: 0.95rem;
        padding: 0.85rem;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s ease;
        letter-spacing: 0.3px;
    }

        .filtre-uygula-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(46,109,164,0.35);
        }

        .filtre-uygula-btn:disabled {
            opacity: 0.5;
            cursor: default;
            transform: none;
            box-shadow: none;
        }

    @@media (max-width: 768px) {
        .oda-sayfa-duzeni {
            flex-direction: column;
        }

        .filtre-panel {
            width: 100%;
            position: static;
        }
    }
</style>

<div id="odalarView">

    <div class="odalar-hero">
        <div class="container">
            <h1>🛏️ Odalarımız</h1>
            <p>Fethiye'nin eşsiz manzarasına karşı konforlu konaklama seçenekleri</p>
        </div>
    </div>

    <section class="bolum" style="background: var(--kum);">
        <div class="container">

            @if (uyeGiris)
            {
                <div style="
            background: #e8f5e9;
            padding: 10px 15px;
            border-radius: 10px;
            text-align: center;
            color: #2e7d32;
            margin: 15px auto;
            max-width: 600px;
        ">
                    🎉 Üye girişi yaptınız! Tüm odalarda <strong>%10 indirim</strong> otomatik uygulandı.
                </div>
            }

            <div class="oda-selector" id="odaSelector">
                <div class="oda-selector-text" id="odaSelectorText">🏠 Tüm Odalar</div>
                <div class="oda-selector-dropdown" id="odaSelectorDropdown">
                    <div class="oda-selector-option" data-tip="tumu"><span class="oda-emoji">🏠</span> Tüm Odalar</div>
                    <div class="oda-selector-option" data-tip="standart"><span class="oda-emoji">🛏️</span> Standart Oda</div>
                    <div class="oda-selector-option" data-tip="suit"><span class="oda-emoji">🌅</span> Suit Oda</div>
                    <div class="oda-selector-option" data-tip="deluxe"><span class="oda-emoji">✨</span> Deluxe Oda</div>
                    <div class="oda-selector-option" data-tip="aile"><span class="oda-emoji">👨‍👩‍👧‍👦</span> Aile Odası</div>
                </div>
            </div>

            <div class="oda-sayfa-duzeni">
                <div class="oda-grid-alani">
                    <div id="kupAlani">
                        <div class="kup-grid" id="kupGrid"></div>
                    </div>
                </div>

                <div class="filtre-panel" id="filtrePanel">
                    <div class="filtre-ust-baslik">Filtreler</div>
                    <div class="filtre-alt-baslik">💰 Fiyat Filtresi</div>
                    <div class="filtre-cizgi-wrap">
                        <div class="filtre-cizgi"></div>
                        <input type="range" id="filtreMin" min="0" max="10000" value="0" step="100" />
                        <input type="range" id="filtreMax" min="0" max="10000" value="10000" step="100" />
                    </div>
                    <div class="filtre-degerler">
                        <span id="filtreMinDeger">0 ₺</span>
                        <span id="filtreMaxDeger">0 ₺</span>
                    </div>
                    <div class="filtre-alt-baslik" style="margin-top: 0.8rem;">👥 Kişi Sayısı</div>
                    <div class="filtre-cizgi-wrap">
                        <div class="filtre-cizgi"></div>
                        <input type="range" id="kisiMin" min="1" max="6" value="1" step="1" />
                        <input type="range" id="kisiMax" min="1" max="6" value="6" step="1" />
                    </div>
                    <div class="filtre-degerler">
                        <span id="kisiMinDeger">1</span>
                        <span id="kisiMaxDeger">6</span>
                    </div>
                    <button class="filtre-uygula-btn" id="filtreUygula">Filtreyi Uygula</button>
                </div>
            </div>

            @if (!uyeGiris)
            {
                <div class="text-center mt-5 p-4" id="uyeDavet"
                     style="background: var(--beyaz); border-radius: 20px; box-shadow: 0 4px 20px rgba(26,58,92,0.08);">
                    <p style="font-size:1.05rem; color: var(--metin-orta); margin-bottom: 1rem;">
                        🎁 <strong>Üye girişi yaparak tüm odalarda %10 indirim kazanın!</strong>
                    </p>
                    <a href="/Home/Giris" class="btn-rezervasyon">🔑 Üye Girişi Yap</a>
                </div>
            }

        </div>
    </section>

</div>

<div id="detayView"></div>

