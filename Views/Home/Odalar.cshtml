                kupGrid.innerHTML += kupHtml(oda, tipAdi);
            }

            if (uyeDavet) uyeDavet.style.display = "none";

            var inceleBtns = kupGrid.querySelectorAll(".kup-incele");
            for (var j = 0; j < inceleBtns.length; j++) {
                (function(btn) {
                    btn.addEventListener("click", function() {
