                })(inceleBtns[j]);
            }

            filtreAralikGuncelle();
        }

        function tumOdalariGoster() {
            seciliTip = null;
            oncekiGoruntu = "tumu";
            detayView.classList.remove("goster");
            detayView.innerHTML = "";

            odaView.style.display = "";
