 
@{
    ViewData["Title"] = ViewBag.OdaAd + " - Detay";

    string odaId = ViewBag.OdaId ?? "standart";
    string odaAd = ViewBag.OdaAd ?? "Oda";
    string odaAciklama = ViewBag.OdaAciklama ?? "";
    string odaEmoji = ViewBag.OdaEmoji ?? "🛏️";
}

<section class="section" style="background: var(--kum);">
    <div class="container">

        <a href="/Home/Odalar"
           style="display:inline-flex; align-items:center; gap:0.4rem;
                  color: var(--ege-orta); font-weight:600; margin-bottom:1.5rem;
                  font-size:0.95rem; transition: color 0.2s;">
            ← Tüm Odalara Dön
        </a>

        <div class="row g-4 align-items-start">

            <div class="col-lg-6">
                <div class="detay-hero-foto
                     @(odaId == "standart" ? "oda-foto-standart" :
                                                                  odaId == "suit" ? "oda-foto-suit" :
                                                                  odaId == "deluxe" ? "oda-foto-deluxe" : "oda-foto-aile")">
                    @odaEmoji
                </div>

                <div style="display:flex; gap:0.8rem; margin-top: 0.8rem;">
                    <div class="gallery-item" style="height:100px; border-radius:12px; flex:1; font-size:2rem;">
                        🛏️
                    </div>
                    <div class="gallery-item" style="height:100px; border-radius:12px; flex:1; font-size:2rem; background: linear-gradient(135deg,#d0e8f5,#b0d4ec);">
                        🪟
                    </div>
                    <div class="gallery-item" style="height:100px; border-radius:12px; flex:1; font-size:2rem; background: linear-gradient(135deg,#e8f0d0,#cce0a8);">
                        🚿
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="detay-info-card">
                    <h1>@odaAd</h1>

                    <div style="display:flex; gap:0.8rem; margin: 0.8rem 0 1.2rem; flex-wrap:wrap;">
                        @if (odaId == "suit" || odaId == "deluxe")
                        {
                            <span class="feature-badge" style="background:var(--altin); color:var(--ege-koyu);">⭐ Premium</span>
                        }
                        @{
                            var kapasiteMap = new Dictionary<string, string>
                                                {
                                                {"standart", "1-2"},
                                                {"suit",     "1-2"},
                                                {"deluxe",   "1-3"},
                                                {"aile",     "2-6"}
                                                };
                            var kisi = kapasiteMap.ContainsKey(odaId) ? kapasiteMap[odaId] : "1-2";
                        }
                        <span class="feature-badge">👥 @kisi Kişi</span>
                        <span class="feature-badge">📐 35-50 m²</span>
                        <span class="feature-badge">🌊 Deniz Manzarası</span>
                    </div>

                    <p style="color: var(--metin-orta); line-height: 1.8; margin-bottom: 1.5rem; font-size: 1rem;">
                        @odaAciklama
                    </p>

                    <h5 style="color: var(--ege-koyu); margin-bottom: 1rem; font-size: 1.05rem;">
                        🏠 Oda Özellikleri
                    </h5>

                    <ul class="detay-ozellik-listesi">
                        <li>❄️ Klima (Isıtma/Soğutma)</li>
                        <li>📶 Ücretsiz Yüksek Hızlı WiFi</li>
                        <li>🍳 Açık Büfe Kahvaltı Dahil</li>
                        <li>📺 Smart LCD TV (50")</li>
                        <li>🚿 Özel Banyo & Duş</li>
                        <li>☕ Çay / Kahve Makinesi</li>
                        @if (odaId == "suit" || odaId == "deluxe")
                        {
                            <li>🛁 Küvet / Jakuzi</li>
                            <li>🌿 Minibar</li>
                        }
                        @if (odaId == "deluxe")
                        {
                            <li>🍾 Karşılama İçeceği</li>
                            <li>💆 SPA İndirimi (%20)</li>
                        }
                        @if (odaId == "aile")
                        {
                            <li>👶 Bebek Yatağı (Talep Üzerine)</li>
                            <li>🎮 Oyun Konsolu</li>
                        }
                        <li>🧴 Özel Banyo Ürünleri</li>
                        <li>🔒 Elektronik Kasa</li>
                    </ul>

                    <div style="background: var(--ege-cok-acik); border-radius: 14px;
                                padding: 1.2rem 1.5rem; margin-top: 1.5rem;
                                display: flex; justify-content: space-between; align-items: center; flex-wrap:wrap; gap:1rem;">
                        <div>
                            <div style="font-size:0.85rem; color:var(--metin-orta);">Gecelik fiyat</div>
                            <div class="fiyat-yeni" style="font-size:2rem;">
                                @{
                                    var fiyatMap = new Dictionary<string, string>
                                                                {
                                                                {"standart", "1.200"},
                                                                {"suit",     "2.500"},
                                                                {"deluxe",   "3.800"},
                                                                {"aile",     "4.200"}
                                                                };
                                    var fiyat = fiyatMap.ContainsKey(odaId) ? fiyatMap[odaId] : "—";
                                }
                                @fiyat ₺ <span>/ gece</span>
                            </div>
                        </div>
                        <div style="font-size:0.8rem; color:var(--metin-orta); max-width:180px;">
                            ✅ Ücretsiz iptal (3 gün öncesine kadar)
                        </div>
                    </div>

                    <a href="/Home/Rezervasyon?odaTipi=@odaAd" class="btn-ayirt">
                        📋 Bu Odayı Ayırt
                    </a>
                </div>
            </div>

        </div>
    </div>
</section>