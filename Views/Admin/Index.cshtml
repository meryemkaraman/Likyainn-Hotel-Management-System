@model List<Likyainn.Models.Rezervasyon>

<h2>Rezervasyon Listesi</h2>

<div style="display:flex; gap:20px; margin:20px 0;">

    <div style="background:#1f4e79;color:white;padding:20px;border-radius:12px;width:220px;">
        <h4>👤 Toplam Üye</h4>
        <h2>@ViewBag.ToplamUye</h2>
    </div>

    <div style="background:#2e8b57;color:white;padding:20px;border-radius:12px;width:220px;">
        <h4>📋 Rezervasyon</h4>
        <h2>@ViewBag.ToplamRezervasyon</h2>
    </div>

    <div style="background:#d4a017;color:white;padding:20px;border-radius:12px;width:220px;">
        <h4>💰 Kazanç</h4>
   <h2>@String.Format("{0:N0}", ViewBag.ToplamKazanc) ₺</h2>
    </div>

</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Ad</th>
            <th>Soyad</th>
            <th>Telefon</th>
            <th>Oda Tipi</th>
            <th>Giriş Tarihi</th>
            <th>Çıkış Tarihi</th>
            <th>Tutar</th>
            <th>İşlem</th>
            <th>Detay</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.Ad</td>
                <td>@r.Soyad</td>
                <td>@r.Telefon</td>
                <td>@r.OdaTipi</td>
                <td>@r.GirisTarihi.ToShortDateString()</td>
                <td>@r.CikisTarihi.ToShortDateString()</td>
                <td>@r.ToplamTutar ₺</td>

                <td>
                    <a asp-action="Sil"
                       asp-route-id="@r.Id"
                       class="btn btn-danger btn-sm">
                        Sil
                    </a>
                </td>
                <td>
                    <a asp-action="Detay"
                       asp-route-id="@r.Id"
                       class="btn btn-info btn-sm">
                        Detay
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
<hr />

<h2>Kayıtlı Üyeler</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Ad</th>
            <th>Soyad</th>
            <th>Email</th>
            <th>Kullanıcı Adı</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var u in ViewBag.Uyeler)
        {
            <tr>
                <td>@u.Ad</td>
                <td>@u.Soyad</td>
                <td>@u.Email</td>
                <td>@u.KullaniciAdi</td>
            </tr>
        }
    </tbody>
</table>